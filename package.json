{
  "name": "greenland-mini4wd",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "catalog:reconcile": "node scripts/build-catalog-reconciled-seed.mjs",
    "test:ui": "NODE_ENV=test vitest run",
    "test:catalog": "NODE_ENV=test vitest run --config vitest.catalog.config.ts",
    "pretest": "npm run catalog:reconcile",
    "test": "npm run test:ui && npm run test:catalog",
    "prebuild": "npm run catalog:reconcile",
    "build": "npm run test:ui && npm run test:catalog && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
